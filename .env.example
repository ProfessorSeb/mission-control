# Database
DATABASE_URL="file:./dev.db"

# Optional: override where OpenClaw stores sessions/logs
# OPENCLAW_HOME="/home/you/.openclaw"

# Optional: specify which Gmail account to use with `gog`
# If omitted, Mission Control will use `gog auth status` to discover the default account.
# GOG_ACCOUNT="you@company.com"

# Notes + sketches vault (outside the repo)
# In Sebby's OpenClaw layout the repo lives in: <workspace>/repos/mission-control
# so this resolves to: <workspace>/mission-control-vault
MISSION_CONTROL_VAULT_DIR="../../mission-control-vault"

# Optional auth gate (recommended if you expose Mission Control publicly, e.g. via ngrok)
# If MC_AUTH_PASSWORD is set, Mission Control requires HTTP Basic Auth.
# MC_AUTH_USER="admin"
# MC_AUTH_PASSWORD="change-me"
