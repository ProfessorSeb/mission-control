// Prisma schema for Mission Control

generator client {
  provider = "prisma-client-js"
  // Keep the client in-repo so it's easy to deploy without a separate build step.
  output = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum TaskStatus {
  INBOX
  DOING
  WAITING
  BLOCKED
  DONE
}

enum TaskPriority {
  P0
  P1
  P2
  P3
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?

  status   TaskStatus   @default(INBOX)
  priority TaskPriority @default(P2)
  dueAt    DateTime?

  // Metadata / integrations
  source String?

  // Linkage keys for external systems (unique where present)
  runKey         String? @unique
  googleTaskKey  String? @unique
  googleTaskListId String?
  googleTaskId     String?
  googleTaskWebViewLink String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, priority])
  @@index([updatedAt])
}

model EmailWatch {
  id      String  @id @default(cuid())
  name    String
  query   String
  enabled Boolean @default(true)

  // Practical guardrail to avoid hammering Gmail.
  maxResults Int @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
  @@index([updatedAt])
}
